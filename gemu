<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>連打バトル</title>
<style>
body{
    margin:0;
    font-family:sans-serif;
    background:linear-gradient(135deg,#141e30,#243b55);
    color:white;
    text-align:center;
}
h1{
    margin-top:30px;
}
.container{
    display:flex;
    justify-content:space-around;
    margin-top:40px;
}
.player{
    width:40%;
}
.bar{
    height:30px;
    background:cyan;
    width:0%;
    transition:0.1s;
}
#bar2{
    background:red;
}
button{
    margin-top:30px;
    padding:10px 30px;
    border:none;
    border-radius:20px;
    background:white;
    font-weight:bold;
    cursor:pointer;
}
</style>
</head>
<body>

<h1>🔥 連打バトル 🔥</h1>
<p>Aキー vs Lキー（10秒勝負）</p>

<div class="container">
    <div class="player">
        <h2>プレイヤー1 (A)</h2>
        <div class="bar" id="bar1"></div>
        <p id="score1">0</p>
    </div>
    <div class="player">
        <h2>プレイヤー2 (L)</h2>
        <div class="bar" id="bar2"></div>
        <p id="score2">0</p>
    </div>
</div>

<button onclick="startGame()">スタート</button>
<p id="result"></p>

<script>
let score1 = 0;
let score2 = 0;
let playing = false;

function startGame(){
    score1 = 0;
    score2 = 0;
    playing = true;
    document.getElementById("result").textContent = "";
    updateUI();

    setTimeout(()=>{
        playing = false;
        if(score1 > score2){
            document.getElementById("result").textContent = "🎉 プレイヤー1の勝ち！";
        } else if(score2 > score1){
            document.getElementById("result").textContent = "🎉 プレイヤー2の勝ち！";
        } else {
            document.getElementById("result").textContent = "🤝 引き分け！";
        }
    },10000);
}

document.addEventListener("keydown", function(e){
    if(!playing) return;

    if(e.key === "a" || e.key === "A"){
        score1++;
    }
    if(e.key === "l" || e.key === "L"){
        score2++;
    }
    updateUI();
});

function updateUI(){
    document.getElementById("score1").textContent = score1;
    document.getElementById("score2").textContent = score2;

    document.getElementById("bar1").style.width = score1 + "%";
    document.getElementById("bar2").style.width = score2 + "%";
}
</script>

</body>
</html>
