<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>Speed Click Challenge</title>
<style>
    body {
        margin: 0;
        font-family: Arial, sans-serif;
        background: linear-gradient(135deg, #1e3c72, #2a5298);
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        color: white;
        text-align: center;
    }

    .game-box {
        background: rgba(0,0,0,0.6);
        padding: 40px;
        border-radius: 20px;
        box-shadow: 0 0 25px cyan;
        width: 320px;
    }

    h1 {
        margin-bottom: 20px;
    }

    #target {
        width: 80px;
        height: 80px;
        background: red;
        border-radius: 50%;
        margin: 20px auto;
        cursor: pointer;
        display: none;
        transition: 0.2s;
    }

    #target:hover {
        transform: scale(1.1);
    }

    button {
        padding: 10px 20px;
        border: none;
        border-radius: 20px;
        background: cyan;
        color: black;
        font-weight: bold;
        cursor: pointer;
        margin-top: 15px;
    }

    button:hover {
        background: white;
    }
</style>
</head>
<body>

<div class="game-box">
    <h1>⚡ Speed Click ⚡</h1>
    <p id="message">スタートを押してね！</p>
    <div id="target"></div>
    <button onclick="startGame()">スタート</button>
</div>

<script>
let startTime;

function startGame() {
    document.getElementById("message").textContent = "待って...";
    document.getElementById("target").style.display = "none";

    const delay = Math.random() * 3000 + 1000;

    setTimeout(() => {
        document.getElementById("message").textContent = "クリック！";
        document.getElementById("target").style.display = "block";
        startTime = new Date().getTime();
    }, delay);
}

document.getElementById("target").onclick = function() {
    const endTime = new Date().getTime();
    const reaction = (endTime - startTime) / 1000;
    document.getElementById("message").textContent =
        "反応速度: " + reaction + " 秒";
    this.style.display = "none";
}
</script>

</body>
</html>
